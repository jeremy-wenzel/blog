---
import Layout from "../layouts/Layout.astro";

// TODO: Will only use a few posts from all the posts. Maybe the latest few.
const allposts = await Astro.glob("./blog/*.md");
---

<Layout>
  <h1>Nerd's home for shit he learns</h1>
  <p>
    This is a place for mainly for me to write out things that I learn. Although
    it would be if it helped someone else. Hopefully it does.
  </p>
  <h3>Blog posts</h3>
  <ul>
    {
      allposts.map((post) => (
        <li>
          <a href={post.url}>{post.frontmatter.title}</a>
        </li>
      ))
    }
  </ul>
</Layout>
