---
import BlogCard from "../components/BlogCard.astro";
import Layout from "../layouts/Layout.astro";
import { sortMarkdownPostsByDate } from "../utils/blogMetadata";

const isDraft = (post: { frontmatter?: { draft?: boolean } }) => post.frontmatter?.draft === true;
const latestPosts = sortMarkdownPostsByDate(await Astro.glob("./blog/*.md"))
  .filter((post) => (import.meta.env.PROD ? !isDraft(post) : true))
  .slice(0, 10);
---

<Layout>
  <section class="home-intro">
    <h1>Nerd's home for shit he learns</h1>
    <p>
      This is a place for mainly for me to write out things that I learn. Although
      it would be if it helped someone else. Hopefully it does.
    </p>
  </section>

  <section class="posts-preview" data-blog-list="latest">
    <div class="posts-preview__header">
      <div>
        <p class="posts-preview__label">Recent entries</p>
        <h2>Latest Posts</h2>
      </div>
      <a class="posts-preview__archive-link" href="/blog/">Browse the archive →</a>
    </div>

    <ul class="blog-card-list" data-blog-card-list="vertical">
      {
        latestPosts.map((post) => (
          <li class="blog-card-list__item">
            <BlogCard post={post} />
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .home-intro {
    margin-bottom: 3rem;
  }

  .home-intro__label,
  .posts-preview__label {
    margin-bottom: 0.75rem;
    color: color-mix(in srgb, var(--link) 72%, white 28%);
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .posts-preview__header {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .posts-preview__header h2 {
    margin: 0;
  }

  .posts-preview__archive-link {
    white-space: nowrap;
    font-weight: 600;
  }

  @media (max-width: 767px) {
    .posts-preview__header {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
