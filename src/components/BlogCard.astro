---
import {
  formatPostDate,
  getPostExcerpt,
  getReadingTimeMinutes,
} from "../utils/blogMetadata";
import type { AstroMarkdownPage } from "../utils/blogMetadata";

const { post } = Astro.props as { post: AstroMarkdownPage };
const title = post.frontmatter.title ?? "Untitled post";
const postUrl = post.url ?? "/";
const formattedDate = formatPostDate(post.frontmatter.date);
const readingTimeMinutes = getReadingTimeMinutes(post);
const excerpt = getPostExcerpt(post);
const hasMetadata = Boolean(formattedDate) || readingTimeMinutes > 0;
---

<article class="blog-card" data-blog-card>
  <div class="blog-card__eyebrow">cat {postUrl}</div>
  <h2 class="blog-card__title">
    <a href={postUrl}>
      {title}
    </a>
  </h2>
  {
    hasMetadata && (
      <div class="blog-card__meta" aria-label="Post metadata">
        {formattedDate && <span>{formattedDate}</span>}
        {formattedDate && readingTimeMinutes > 0 && <span aria-hidden="true">•</span>}
        {readingTimeMinutes > 0 && <span>{readingTimeMinutes} min read</span>}
      </div>
    )
  }
  <p class="blog-card__excerpt">{excerpt}</p>
  <a class="blog-card__link" href={postUrl}>Read →</a>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
    padding: clamp(1.5rem, 2vw, 1.9rem);
    border: 1px solid color-mix(in srgb, var(--link) 24%, transparent);
    border-radius: 1rem;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--main) 88%, black) 0%, color-mix(in srgb, var(--main) 96%, white) 100%);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--main) 65%, black 35%);
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--primary) 72%, white 28%);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.28);
  }

  .blog-card__eyebrow {
    color: color-mix(in srgb, var(--link) 72%, white 28%);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-card__title {
    margin: 0;
    font-size: clamp(1.45rem, 2.2vw, 1.9rem);
    line-height: 1.2;
  }

  .blog-card__title a {
    color: var(--primary);
  }

  .blog-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    color: color-mix(in srgb, var(--text) 72%, black 28%);
    font-size: 0.92rem;
  }

  .blog-card__excerpt {
    margin: 0;
    color: color-mix(in srgb, var(--text) 92%, black 8%);
    line-height: 1.7;
  }

  .blog-card__link {
    width: fit-content;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  @media (min-width: 768px) {
    .blog-card {
      padding-inline: clamp(1.75rem, 3vw, 2.5rem);
    }
  }
</style>
